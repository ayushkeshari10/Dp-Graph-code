class Solution {
    int helper(vector<int> &dp,int n){
        if(n<=1){
            return n;
        }
        if(n==2){
            return 1;
        }
        if(dp[n]!=-1){
            return dp[n];
        }
        return dp[n]=helper(dp,n-1)+helper(dp,n-2)+helper(dp,n-3);
    }
public:
    int tribonacci(int n) {
        vector<int> dp(n+1,-1);
        return helper(dp,n);
    }
};
