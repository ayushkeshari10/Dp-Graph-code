class Solution {
public:
    bool isBipartite(vector<vector<int>>& graph) {
        int n=graph.size();
        vector<int>color(n,-1);
        queue<int>q;
        for(int i=0;i<n;i++){
            if(color[i]==-1){
                color[i]=0;
                q.push(i);
                while(!q.empty()){
                    int node=q.front();
                    q.pop();
                    for(int x:graph[node]){
                        if(color[x]==-1){
                            color[x]=(color[node]+1)%2;
                            q.push(x);
                        }
                        else{
                            if(color[x]==color[node]){
                                return 0;
                            }
                        }
                    }
                }
            }
        }
        return 1;
    }
};
